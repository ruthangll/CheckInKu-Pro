{
  "expo": {
    "name": "CheckInKu Pro",
    "slug": "checkinku-pro",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/icon.png",

    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "CheckInKu Pro membutuhkan akses galeri untuk memilih foto check-in.",
          "cameraPermission": "CheckInKu Pro membutuhkan akses kamera untuk mengambil foto check-in."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CheckInKu Pro membutuhkan lokasi untuk menyimpan data check-in."
        }
      ]
    ],

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A84FF"
    },

    "android": {
      "package": "com.ruthangelsitorus.checkinkupro",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A84FF"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION"
      ]
    },

    "extra": {
      "eas": {
        "projectId": "f77f78c6-4987-43d3-b724-b6de18fe0f34"
      }
    }
  }
}